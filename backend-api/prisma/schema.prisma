// ============================================================
// BETA Universal Service Marketplace — Prisma Schema
// Production-grade database schema with PostGIS support
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, pgcrypto, uuid_ossp(map: "uuid-ossp")]
}

// ============================================================
// USER
// ============================================================

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalAuthId String   @unique @map("external_auth_id")
  email          String   @unique
  name           String
  phone          String?
  avatarUrl      String?  @map("avatar_url")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  bookings      Booking[]
  payments      Payment[]
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]

  @@index([email])
  @@index([externalAuthId])
  @@index([deletedAt])
  @@map("users")
}

// ============================================================
// BOOKING TYPE — Level 1 hierarchy (Appointments, Rentals, etc.)
// ============================================================

model BookingType {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  iconName    String? @map("icon_name")        // lucide icon name e.g. "calendar"
  coverImage  String? @map("cover_image")
  color       String? // hex color for gradient
  gradient    String? // CSS gradient string
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  isFeatured  Boolean @default(false) @map("is_featured")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categories ServiceCategory[]
  merchants  Merchant[]

  @@index([slug])
  @@index([sortOrder])
  @@index([isActive])
  @@map("booking_types")
}

// ============================================================
// SERVICE CATEGORY — Level 2 hierarchy
// ============================================================

model ServiceCategory {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingTypeId String? @map("booking_type_id") @db.Uuid
  parentId      String? @map("parent_id") @db.Uuid   // for sub-subcategories
  name          String
  slug          String  @unique
  description   String? @db.Text
  iconName      String? @map("icon_name")             // lucide icon name
  iconUrl       String? @map("icon_url")
  coverImage    String? @map("cover_image")
  color         String? // hex color for UI
  sortOrder     Int     @default(0) @map("sort_order")
  isActive      Boolean @default(true) @map("is_active")
  isFeatured    Boolean @default(false) @map("is_featured")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  bookingType BookingType?      @relation(fields: [bookingTypeId], references: [id])
  parent      ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ServiceCategory[] @relation("CategoryHierarchy")
  services    Service[]

  @@index([slug])
  @@index([sortOrder])
  @@index([bookingTypeId])
  @@index([parentId])
  @@map("service_categories")
}

// ============================================================
// MERCHANT — Service provider
// ============================================================

model Merchant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId       String   @map("owner_id") @db.Uuid
  bookingTypeId String?  @map("booking_type_id") @db.Uuid
  name          String
  slug          String   @unique
  description   String?  @db.Text
  shortBio      String?  @map("short_bio") @db.VarChar(300)
  logoUrl       String?  @map("logo_url")
  coverImageUrl String?  @map("cover_image_url")
  images        String[] @default([])
  email         String
  phone         String?
  website       String?

  // Address
  address    String
  city       String
  state      String
  country    String   @default("IN")
  postalCode String   @map("postal_code")

  // Geolocation (PostGIS)
  latitude  Float
  longitude Float

  // Settings
  timezone       String  @default("Asia/Kolkata")
  currency       String  @default("INR")
  isVerified     Boolean @default(false) @map("is_verified")
  isActive       Boolean @default(true) @map("is_active")
  isFeatured     Boolean @default(false) @map("is_featured")
  amenities      String[] @default([])
  openingHours   Json?    @map("opening_hours") // { MON: { open: "09:00", close: "18:00" }, ... }
  tags           String[] @default([])
  socialLinks    Json?    @map("social_links")  // { instagram, facebook, twitter }

  // Aggregates
  rating      Float @default(0)
  reviewCount Int   @default(0) @map("review_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  bookingType BookingType?    @relation(fields: [bookingTypeId], references: [id])
  services    Service[]
  staff       MerchantStaff[]
  bookings    Booking[]
  reviews     Review[]

  @@index([slug])
  @@index([ownerId])
  @@index([bookingTypeId])
  @@index([city])
  @@index([isActive])
  @@index([isFeatured])
  @@index([latitude, longitude])
  @@index([deletedAt])
  @@map("merchants")
}

model MerchantStaff {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId   String       @map("merchant_id") @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  name         String
  role         MerchantRole @default(STAFF)
  avatarUrl    String?      @map("avatar_url")
  designation  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, userId])
  @@index([userId])
  @@map("merchant_staff")
}

enum MerchantRole {
  OWNER
  ADMIN
  STAFF
}

// ============================================================
// SERVICE
// ============================================================

model Service {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId       String      @map("merchant_id") @db.Uuid
  categoryId       String      @map("category_id") @db.Uuid
  name             String
  slug             String
  description      String      @db.Text
  shortDescription String      @map("short_description") @db.VarChar(255)
  serviceType      ServiceType @default(APPOINTMENT) @map("service_type")
  durationMinutes  Int         @map("duration_minutes")
  bufferMinutes    Int         @default(0) @map("buffer_minutes")
  basePrice        Decimal     @map("base_price") @db.Decimal(10, 2)
  currency         String      @default("INR")
  maxCapacity      Int         @default(1) @map("max_capacity")
  images           String[]    @default([])
  tags             String[]    @default([])
  isActive         Boolean     @default(true) @map("is_active")
  isFeatured       Boolean     @default(false) @map("is_featured")
  metadata         Json?       // flexible extra data per service type

  // Aggregates
  rating      Float @default(0)
  reviewCount Int   @default(0) @map("review_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  merchant          Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category          ServiceCategory    @relation(fields: [categoryId], references: [id])
  availabilityRules AvailabilityRule[]
  slots             BookingSlot[]
  bookings          Booking[]
  reviews           Review[]
  favorites         Favorite[]

  @@unique([merchantId, slug])
  @@index([merchantId])
  @@index([categoryId])
  @@index([serviceType])
  @@index([isActive, isFeatured])
  @@index([deletedAt])
  @@map("services")
}

enum ServiceType {
  APPOINTMENT
  RESERVATION
  RENTAL
  TICKET
  MEETING
  CLASS
  EVENT
  VEHICLE_SERVICE
}

// ============================================================
// AVAILABILITY
// ============================================================

model AvailabilityRule {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId  String    @map("service_id") @db.Uuid
  dayOfWeek  DayOfWeek @map("day_of_week")
  startTime  String    @map("start_time") // HH:mm format
  endTime    String    @map("end_time")   // HH:mm format
  isActive   Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, dayOfWeek])
  @@map("availability_rules")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ============================================================
// BOOKING SLOT
// ============================================================

model BookingSlot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId   String   @map("service_id") @db.Uuid
  date        DateTime @db.Date
  startTime   DateTime @map("start_time") @db.Timestamptz
  endTime     DateTime @map("end_time") @db.Timestamptz
  maxCapacity Int      @map("max_capacity")
  bookedCount Int      @default(0) @map("booked_count")
  price       Decimal  @db.Decimal(10, 2)
  isBlocked   Boolean  @default(false) @map("is_blocked")
  isAvailable Boolean  @default(true) @map("is_available")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  service  Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([serviceId, startTime])
  @@index([serviceId, date])
  @@index([date, isAvailable])
  @@index([startTime])
  @@map("booking_slots")
}

// ============================================================
// BOOKING
// ============================================================

model Booking {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingReference String        @unique @map("booking_reference")
  userId           String        @map("user_id") @db.Uuid
  serviceId        String        @map("service_id") @db.Uuid
  merchantId       String        @map("merchant_id") @db.Uuid
  slotId           String        @map("slot_id") @db.Uuid
  status           BookingStatus @default(PENDING)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency         String        @default("INR")
  attendeeCount    Int           @default(1) @map("attendee_count")
  notes            String?       @db.Text
  bookedAt         DateTime      @default(now()) @map("booked_at")
  scheduledStart   DateTime      @map("scheduled_start") @db.Timestamptz
  scheduledEnd     DateTime      @map("scheduled_end") @db.Timestamptz
  cancelledAt      DateTime?     @map("cancelled_at")
  cancelReason     String?       @map("cancel_reason")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user      User        @relation(fields: [userId], references: [id])
  service   Service     @relation(fields: [serviceId], references: [id])
  merchant  Merchant    @relation(fields: [merchantId], references: [id])
  slot      BookingSlot @relation(fields: [slotId], references: [id])
  payment   Payment?
  qrCheckin QRCheckin?
  review    Review?

  @@index([userId])
  @@index([merchantId])
  @@index([serviceId])
  @@index([status])
  @@index([scheduledStart])
  @@index([bookingReference])
  @@index([deletedAt])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  CHECKED_IN
  REFUNDED
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId         String          @unique @map("booking_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("INR")
  provider          PaymentProvider
  providerPaymentId String?         @map("provider_payment_id")
  providerOrderId   String?         @map("provider_order_id")
  status            PaymentStatus   @default(PENDING)
  metadata          Json?
  paidAt            DateTime?       @map("paid_at")
  refundedAt        DateTime?       @map("refunded_at")
  refundAmount      Decimal?        @map("refund_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider, providerPaymentId])
  @@index([status])
  @@map("payments")
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ============================================================
// QR CHECK-IN
// ============================================================

model QRCheckin {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId     String    @unique @map("booking_id") @db.Uuid
  qrToken       String    @unique @map("qr_token")
  status        QRStatus  @default(ACTIVE)
  checkedInAt   DateTime? @map("checked_in_at")
  checkedInById String?   @map("checked_in_by_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([qrToken])
  @@index([status])
  @@index([expiresAt])
  @@map("qr_checkins")
}

enum QRStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String  @map("user_id") @db.Uuid
  serviceId  String  @map("service_id") @db.Uuid
  merchantId String  @map("merchant_id") @db.Uuid
  bookingId  String  @unique @map("booking_id") @db.Uuid
  rating     Int     // 1-5
  comment    String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user     User     @relation(fields: [userId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])
  booking  Booking  @relation(fields: [bookingId], references: [id])

  @@index([serviceId, rating])
  @@index([merchantId])
  @@index([userId])
  @@map("reviews")
}

// ============================================================
// FAVORITE
// ============================================================

model Favorite {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  serviceId String @map("service_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("favorites")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String           @map("user_id") @db.Uuid
  type    NotificationType
  title   String
  message String           @db.Text
  data    Json?
  isRead  Boolean          @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  CHECKIN_SUCCESS
  REVIEW_REQUEST
}
